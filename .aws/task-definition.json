{
  "family": "partion-matching-engine",
  "containerDefinitions": [
    {
      "name": "matching-engine",
      "image": "__MATCHING_ENGINE_IMAGE__",
      "cpu": 0,
      "portMappings": [],
      "essential": true,
      "environment": [
        {
          "name": "DD_SERVICE",
          "value": "__MATCHING_ENGINE_DD_SERVICE__"
        },
        {
          "name": "KAFKA_BOOTSTRAP_SERVERS",
          "value": "__MATCHING_ENGINE_KAFKA_BOOTSTRAP_SERVERS__"
        },
        {
          "name": "DD_ENV",
          "value": "__MATCHING_ENGINE_DD_ENV__"
        },
        {
          "name": "KAFKA_GROUP_ID",
          "value": "__MATCHING_ENGINE_KAFKA_GROUP_ID__"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "dependsOn": [
        {
          "containerName": "datadog-agent",
          "condition": "START"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/partion-matching-engine",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": []
    },
    {
      "name": "datadog-agent",
      "image": "public.ecr.aws/datadog/agent:latest",
      "cpu": 0,
      "portMappings": [],
      "essential": true,
      "environment": [
        {
          "name": "DD_APM_NON_LOCAL_TRAFFIC",
          "value": "__MATCHING_ENGINE_DATADOG_DD_APM_NON_LOCAL_TRAFFIC__"
        },
        {
          "name": "DD_SITE",
          "value": "__MATCHING_ENGINE_DATADOG_DD_SITE__"
        },
        {
          "name": "ECS_FARGATE",
          "value": "__MATCHING_ENGINE_DATADOG_ECS_FARGATE__"
        },
        {
          "name": "DD_APM_ENABLED",
          "value": "__MATCHING_ENGINE_DATADOG_DD_APM_ENABLED__"
        },
        {
          "name": "DD_ENV",
          "value": "__MATCHING_ENGINE_DATADOG_DD_ENV__"
        },
        {
          "name": "DD_LOGS_ENABLED",
          "value": "__MATCHING_ENGINE_DATADOG_DD_LOGS_ENABLED__"
        },
        {
          "name": "DD_DOGSTATSD_NON_LOCAL_TRAFFIC",
          "value": "__MATCHING_ENGINE_DATADOG_DD_DOGSTATSD_NON_LOCAL_TRAFFIC__"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "DD_API_KEY",
          "valueFrom": "__MATCHING_ENGINE_DD_API_KEY_SECRET_ARN__"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/partion-matching-engine",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "datadog-agent"
        }
      },
      "systemControls": []
    }
  ],
  "executionRoleArn": "__MATCHING_ENGINE_EXECUTION_ROLE_ARN__",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024"
}
